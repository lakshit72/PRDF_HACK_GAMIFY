# FutureYou Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/futureyou

# Auth
JWT_SECRET=replace_with_a_very_long_random_string_at_least_32_chars

# ─── AI Coach (Niyati) — Free LLM APIs ────────────────────────────────────────
#
# TIER 1: Hugging Face (RECOMMENDED — truly free, no credit card)
#   1. Sign up at https://huggingface.co
#   2. Go to Settings → Access Tokens → New token (Read permission)
#   3. Paste token below
#   Free tier: ~30,000 requests/month
#
HF_API_TOKEN=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

#
# TIER 2: Cohere (free tier — 100 req/min, 10k req/month)
#   1. Sign up at https://cohere.com
#   2. Dashboard → API Keys → copy key
#
# COHERE_API_KEY=your_cohere_key_here

#
# TIER 3: OpenAI (optional paid fallback)
#   Only used if HF and Cohere both fail.
#
# OPENAI_API_KEY=sk-...

# If NO keys are set above, the AI Coach uses the built-in NPS knowledge base
# (zero cost, zero config, works for ~95% of common NPS questions).

# ─── Image Upload & Caricature Generation ──────────────────────────────────────
#
# Reuses HF_API_TOKEN above (timbrooks/instruct-pix2pix model).
# No extra key needed if HF_API_TOKEN is already set.
#
# Optional DeepAI fallback:
# DEEPAI_API_KEY=your_deepai_key_here

# ─── Future Self / Time Machine (OpenAI — paid) ────────────────────────────────
# Required only for /api/futureself/generate and /api/timemachine/calculate
# OPENAI_API_KEY=sk-...

# ─── Redis (optional — leaderboards fall back to MongoDB) ──────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS (production only) ────────────────────────────────────────────────────
# FRONTEND_URL=https://futureyou-frontend.vercel.app
